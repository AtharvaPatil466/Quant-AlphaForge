<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.alphaforge.prediction.papertrader.place</string>

    <!-- Invoke the wrapper with the `place` subcommand. -->
    <key>ProgramArguments</key>
    <array>
        <string>/Users/atharva/Quant Projects/Quant Alpha/alphaforge-prediction/scripts/run_paper_trader.sh</string>
        <string>place</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/atharva/Quant Projects/Quant Alpha/alphaforge-prediction</string>

    <!-- place 3x/day: 09:00, 15:00, 21:00 local. -->
    <key>StartCalendarInterval</key>
    <array>
        <dict>
            <key>Hour</key><integer>9</integer>
            <key>Minute</key><integer>0</integer>
        </dict>
        <dict>
            <key>Hour</key><integer>15</integer>
            <key>Minute</key><integer>0</integer>
        </dict>
        <dict>
            <key>Hour</key><integer>21</integer>
            <key>Minute</key><integer>0</integer>
        </dict>
    </array>

    <!-- Do not fire at load/login; only on the calendar schedule. -->
    <key>RunAtLoad</key>
    <false/>

    <!-- launchd's own capture of the wrapper's stdout/stderr (the wrapper also
         keeps its own framed per-command daily log under data/paper/logs/). -->
    <key>StandardOutPath</key>
    <string>/Users/atharva/Quant Projects/Quant Alpha/alphaforge-prediction/data/paper/logs/launchd-place.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/atharva/Quant Projects/Quant Alpha/alphaforge-prediction/data/paper/logs/launchd-place.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Library/Frameworks/Python.framework/Versions/3.13/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>LANG</key>
        <string>en_US.UTF-8</string>
    </dict>

    <!-- A missed run (machine asleep) fires once at next wake, not N catch-ups. -->
    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
