# Alpaca Paper Trading API Credentials
# 1. Sign up at https://alpaca.markets (free)
# 2. Go to Dashboard → Paper Trading → Generate API Keys
# 3. Copy this file to .env and fill in your keys
# 4. NEVER commit .env to git (it is gitignored at the repo root)

ALPACA_API_KEY=YOUR_KEY_HERE
ALPACA_SECRET_KEY=YOUR_SECRET_HERE

# Strategy 2 (MARL Ensemble) — separate paper account for clean attribution
ALPACA_API_KEY_MARL=YOUR_MARL_KEY_HERE
ALPACA_SECRET_KEY_MARL=YOUR_MARL_SECRET_HERE
